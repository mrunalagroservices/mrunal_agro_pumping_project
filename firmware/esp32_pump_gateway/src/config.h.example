#pragma once

// ─── WiFi ────────────────────────────────────────────────────────────────
#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// ─── MQTT (HiveMQ Cloud, TLS port 8883) ─────────────────────────────────────
// For local testing against backend/scripts/local-mqtt-broker.js, set
// MQTT_USE_TLS to false, MQTT_HOST to your computer's LAN IP, MQTT_PORT to
// 1883, and leave MQTT_USERNAME/MQTT_PASSWORD empty ("").
#define MQTT_USE_TLS  true
#define MQTT_HOST     "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.s1.eu.hivemq.cloud"
#define MQTT_PORT     8883
#define MQTT_USERNAME "pumpinguser"
#define MQTT_PASSWORD "changeme"

// ─── Device identity — must match a `devices` row in the backend ───────────
// Topics become: farm/{ORG_ID}/{API_KEY}/sensors|status|command
#define ORG_ID            "1"
#define API_KEY           "pump_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#define DEVICE_NAME       "Field Gateway 1"
#define FIRMWARE_VERSION  "1.0.0"

// ─── Relays — GPIO pin per relay channel (1-indexed, matches actuators.relay_channel) ──
#define RELAY_COUNT 4
static const int RELAY_PINS[RELAY_COUNT] = {16, 17, 18, 19};

// Most relay modules are active-LOW: driving the GPIO LOW energizes the relay (motor ON)
#define RELAY_ACTIVE_LOW true

// ─── Sensors — JSON channel name (must match sensors.channel in the backend) ──
//     mapped to an ESP32 ADC pin and a raw->engineering-unit conversion ──────
static inline float convertPercent01(int raw)  { return raw * (100.0f / 4095.0f); }       // 0-100%
static inline float convertVoltage0_250(int raw) { return raw * (250.0f / 4095.0f); }      // 0-250V example

#define SENSOR_COUNT 2
struct SensorConfig { const char *channel; int pin; float (*convert)(int raw); };
static const SensorConfig SENSORS[SENSOR_COUNT] = {
  { "water_level", 34, convertPercent01 },
  { "voltage",     35, convertVoltage0_250 }
};

// ─── Timing ──────────────────────────────────────────────────────────────
#define SENSOR_PUBLISH_INTERVAL_MS 30000  // how often to publish sensor readings
#define STATUS_PUBLISH_INTERVAL_MS 60000  // how often to publish a status/heartbeat
