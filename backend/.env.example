NODE_ENV=development
PORT=3010

# Neon PostgreSQL — separate DB for this project (modeled on the main schema)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/pumping?sslmode=require

# ─── MQTT (HiveMQ Cloud — separate instance for now) ────────────────────────
MQTT_BROKER=mqtts://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=pumpinguser
MQTT_PASSWORD=changeme

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-strong-random-secret-here
JWT_EXPIRES_IN=7d

# Dashboard URL (for CORS in production)
FRONTEND_URL=http://localhost:3000
